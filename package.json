{
  "name": "@davidsneighbour/postshot",
  "version": "0.2.2",
  "description": "Create styled screenshots of social media posts using network adapters and reusable HTML/CSS themes.",
  "type": "module",
  "bin": {
    "postshot": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts --help",
    "check": "tsc -p tsconfig.json --noEmit",
    "publish:local": "node ./scripts/publish.mjs",
    "release:local": "node ./scripts/release-local.mjs"
  },
  "dependencies": {
    "commander": "14.0.3",
    "handlebars": "4.7.8",
    "moment": "^2.29.4",
    "playwright": "1.58.2",
    "png-chunk-text": "1.0.0",
    "png-chunks-encode": "1.0.0",
    "png-chunks-extract": "1.0.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "release-it": "^19.0.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
