<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    {{{themeFontCss}}}
    {{{themeVariableCss}}}
    {{{tailwindCss}}}
    {{{inlineCss}}}
  </style>
</head>

<body class="bg-gradient-to-br from-rose-500 to-orange-400
              text-base text-gray-100 font-sans">

  <div class="flex bg-white shadow-xl rounded-lg mx-4 md:mx-auto my-56 max-w-md md:max-w-2xl">
    <div class="flex items-start px-4 py-6">
      <img class="w-12 h-12 rounded-full object-cover mr-4 shadow"
        src="{{post.author.avatarUrl}}"
        alt="avatar">
      <div class="">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900 -mt-1">{{post.author.displayName}}</h2>
          <small class="text-sm text-gray-700">{{dateFormat post.createdAt format="dddd, MMMM Do YYYY"}}</small>
        </div>
        <p class="text-gray-700">{{post.author.handle}}</p>
        <p class="mt-3 text-gray-700 text-sm">
          {{post.contentText}}
        </p>

        <div class="mt-4 flex items-center gap-3">

          {{#if post.metrics.repliesCount}}
            <div class="flex flex-row justify-normal items-center gap-1 text-gray-700 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-1 -mt-1"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/></svg>
              <span>{{post.metrics.repliesCount}}</span>
            </div>
          {{/if}}

          {{#if post.metrics.reblogsCount}}
            <div class="flex flex-row justify-normal items-center gap-1 text-gray-700 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-1 -mt-1"><path d="m2 9 3-3 3 3"/><path d="M13 18H7a2 2 0 0 1-2-2V6"/><path d="m22 15-3 3-3-3"/><path d="M11 6h6a2 2 0 0 1 2 2v10"/></svg>
              <span>{{post.metrics.reblogsCount}}</span>
            </div>
          {{/if}}

          {{#if post.metrics.favouritesCount}}
            <div class="flex flex-row justify-normal items-center gap-1 text-gray-700 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-1 -mt-1"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
              <span>{{post.metrics.favouritesCount}}</span>
            </div>
          {{/if}}

          {{#if post.metrics.bookmarksCount}}
            <div class="flex flex-row justify-normal items-center gap-1 text-gray-700 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-1 -mt-1"><path d="M17 3a2 2 0 0 1 2 2v15a1 1 0 0 1-1.496.868l-4.512-2.578a2 2 0 0 0-1.984 0l-4.512 2.578A1 1 0 0 1 5 20V5a2 2 0 0 1 2-2z"/></svg>
              <span>{{post.metrics.bookmarksCount}}</span>
            </div>
          {{/if}}

        </div>
      </div>
    </div>
  </div>

</body>

</html>
